# === Core & Server ===
APP_ENV=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# === Database (Async Postgres + pgvector) ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vectordb

# === Auth ===
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-random-32-byte-hex
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# === Azure OpenAI LLMs & Embeddings ===
# Two Models, One Agent (per INSTRUCTIONS.md):
# - Strong model: final agent synthesis (expensive, high quality)
# - Cheap model:  mechanical tasks — arg extraction, RAG query rewrite
# - Embedding:    text-embedding-3-small outputs 1536-dim vectors
# The API key is also stored in HashiCorp Vault at secret/data/travel-planner
# when Vault is reachable. Falls back to this value if Vault is unavailable.
AZURE_OPENAI_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.services.ai.azure.com/openai/v1
AZURE_STRONG_MODEL=your-strong-model-deployment-name
AZURE_CHEAP_MODEL=your-cheap-model-deployment-name
AZURE_EMBEDDING_MODEL=text-embedding-3-small-1

# === LangSmith Tracing ===
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=smart-travel-planner

# === External APIs (pick your stack) ===
WEATHER_API_KEY=...
FLIGHT_API_KEY=...
FX_API_KEY=...

# === Webhook Delivery ===
WEBHOOK_URL=https://discord.com/api/webhooks/...
WEBHOOK_TIMEOUT_SEC=10
WEBHOOK_MAX_RETRIES=3

# === RAG & Caching Tuning ===
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
API_CACHE_TTL_SEC=600

# === HashiCorp Vault ===
# Secrets (JW-SECRET-KEY, AZURE-OPENAI-KEY) are fetched from Vault at
# secret/data/travel-planner if reachable. Falls back to the values above
# if Vault is unavailable.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=myroot
