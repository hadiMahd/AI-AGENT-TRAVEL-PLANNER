# === Core & Server ===
APP_ENV=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# === Database (Async Postgres + pgvector) ===
# REQUIRED. In docker-compose, use service name: postgresql+asyncpg://postgres:pass@db:5432/travel_planner
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/travel_planner

# === Auth ===
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-random-32-byte-hex
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# === LLMs & Embeddings ===
# REQUIRED
OPENAI_API_KEY=sk-...
CHEAP_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# === LangSmith Tracing ===
# REQUIRED for spec deliverable
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=smart-travel-planner

# === External APIs (pick your stack) ===
# REQUIRED by agent tools
WEATHER_API_KEY=...
FLIGHT_API_KEY=...
FX_API_KEY=...

# === Webhook Delivery ===
# REQUIRED
WEBHOOK_URL=https://discord.com/api/webhooks/...
WEBHOOK_TIMEOUT_SEC=10
WEBHOOK_MAX_RETRIES=3

# === RAG & Caching Tuning ===
# OPTIONAL (defaults applied in Settings if missing)
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
API_CACHE_TTL_SEC=600